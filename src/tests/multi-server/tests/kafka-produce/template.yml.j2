timeout: {{ test_timeout }}
state_order: sequence
states:
  state_1:
    description: >
      proto_load on kafka-producer1 generates {{ expected_messages }}
      Access-Requests into its own `recv Access-Request`, each of
      which calls kafka.produce.  Wait for the consumer to report
      PASS with received == expected == {{ expected_messages }}.
    host:
      kafka-producer1:
        actions:
        - execute_command:
            command: "true"
    verify:
      timeout: {{ test_verify_timeout }}
      trigger_mode: unordered
      triggers:
      - kafka-consumer-summary:
          json:
            result:
              pattern:
                reg_pattern: PASS
            expected:
              pattern:
                reg_pattern: "^{{ expected_messages }}$"
            received:
              pattern:
                reg_pattern: "^{{ expected_messages }}$"
